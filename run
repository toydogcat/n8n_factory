#!/bin/bash

# Configuration
CONDA_ENV="toby"
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Colors for better output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${BLUE}🚀 Starting n8n Factory Synergy Mode...${NC}"

# Ensure we're in the right directory
cd "$(dirname "$0")"

# --- IP Synchronization Step ---
echo -e "${BLUE}🔄 Synchronizing IP addresses...${NC}"
if command -v conda &> /dev/null; then
    conda run -n $CONDA_ENV python backend/sync_n8n_ip.py
    echo -e "${BLUE}📦 Installing backend dependencies...${NC}"
    conda run -n $CONDA_ENV pip install -r backend/requirements.txt
else
    python backend/sync_n8n_ip.py
    echo -e "${BLUE}📦 Installing backend dependencies...${NC}"
    pip install -r backend/requirements.txt
fi

# Function to cleanup background processes on exit
cleanup() {
    echo -e "\n${YELLOW}🛑 Shutting down services...${NC}"
    kill $BACKEND_PID $FRONTEND_PID 2>/dev/null
    echo -e "${GREEN}✅ All services stopped.${NC}"
    exit
}

# Trap signals for cleanup
trap cleanup INT TERM

# Start Backend
echo -e "${BLUE}📦 Starting Backend (FastAPI) on port $BACKEND_PORT...${NC}"
# Use conda run if available, otherwise fallback to python
if command -v conda &> /dev/null; then
    conda run -n $CONDA_ENV python backend/main.py &
else
    python backend/main.py &
fi
BACKEND_PID=$!

# Wait a moment for backend to initialize
sleep 2

# Start Frontend
echo -e "${BLUE}🎨 Starting Frontend (Vite) on port $FRONTEND_PORT...${NC}"
cd frontend

# Check for node_modules
if [ ! -d "node_modules" ]; then
    echo -e "${YELLOW}📦 node_modules not found. Installing dependencies...${NC}"
    npm install
fi

npm run dev &
FRONTEND_PID=$!

echo -e "\n${GREEN}✨ n8n Factory is now LIVE!${NC}"
echo -e "📍 ${BLUE}Dashboard:${NC}    http://localhost:$FRONTEND_PORT"
echo -e "📍 ${BLUE}Backend API:${NC}  http://localhost:$BACKEND_PORT"
echo -e "📍 ${BLUE}Live Logs:${NC}    Check the Dashboard"
echo -e "\n${YELLOW}Press Ctrl+C to stop all services.${NC}"

# Keep script running and wait for background processes
wait
