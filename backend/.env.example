# n8n Factory Environment Variables
# Copy this file to .env and fill in your values

# n8n Base URL (e.g. http://localhost:5678 or https://n8n.example.com)
N8N_BASE_URL=http://localhost:5678

# n8n API Key (Generated in n8n Settings > API)
N8N_API_KEY=your_n8n_api_key_here

# Local Webhook Token (For securing incoming calls from n8n)
WEBHOOK_AUTH_TOKEN=secret_token_to_verify_n8n_calls

# Dashboard Settings
DASHBOARD_PORT=8001
BACKEND_PORT=8000
